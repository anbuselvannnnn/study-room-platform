# MongoDB connection string
MONGO_URI=mongodb+srv://youruser:yourpass@cluster.mongodb.net/?appName=Cluster0

# JWT secret for auth tokens (use a long random string in production)
JWT_SECRET=change-me-to-a-random-secret

# Server port (Render/Railway will set this automatically)
PORT=5000

# ===== EMAIL (SMTP) =====
# Gmail: use your Gmail address + App Password
#   1. Enable 2FA on your Google account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Generate a new password, paste it as SMTP_PASS
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# For non-Gmail providers, also set:
# SMTP_HOST=smtp.yourprovider.com
# SMTP_PORT=587

# ===== GROQ API KEY (for AI nerd bot) =====
# Sign up free at https://console.groq.com and get an API key
GROQ_API_KEY=your-groq-api-key
